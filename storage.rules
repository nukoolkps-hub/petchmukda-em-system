rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    function isEmployeeOwner(employeeId) {
      return isSignedIn()
        && firestore.get(/databases/petchmukda-bot/documents/employees/$(employeeId)).data.lineUserId == request.auth.uid;
    }

    function isAdvanceOwner(advanceId) {
      return isEmployeeOwner(
        firestore.get(/databases/petchmukda-bot/documents/advances/$(advanceId)).data.employeeId
      );
    }

    function isLoanOwner(loanId) {
      return isEmployeeOwner(
        firestore.get(/databases/petchmukda-bot/documents/employeeLoans/$(loanId)).data.employeeId
      );
    }

    match /avatars/{employeeId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || isEmployeeOwner(employeeId)) && isImageUpload();
    }

    match /advanceSlips/{advanceId}/{fileName} {
      allow read: if isAdmin() || isAdvanceOwner(advanceId);
      allow write: if isAdmin() && isImageUpload();
    }

    match /loanSlips/{loanId}/{fileName} {
      allow read: if isAdmin() || isLoanOwner(loanId);
      allow write: if isAdmin() && isImageUpload();
    }

    match /salarySlips/{employeeId}/{fileName} {
      allow read: if isAdmin() || isEmployeeOwner(employeeId);
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType == "application/pdf";
    }

    // รูปแนบสรุปเช้า 07:30 — admin อัปโหลด · LINE ดึงผ่าน token URL
    match /dailySummaryImages/{imageId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
