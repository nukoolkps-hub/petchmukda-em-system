// ╔═══════════════════════════════════════════════════════════════════╗
// ║  Firestore Security Rules — copy ไปวางใน Firebase Console         ║
// ║  https://console.firebase.google.com → Firestore → Rules         ║
// ║                                                                  ║
// ║  พื้นฐาน: ผู้ใช้ที่ login แล้วเท่านั้นที่อ่าน/เขียนได้             ║
// ║  อนาคต: ทำ role-based access (admin/employee) ผ่าน custom claims ║
// ╚═══════════════════════════════════════════════════════════════════╝

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isEmployeeOwner(employeeId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/employees/$(employeeId))
        && get(/databases/$(database)/documents/employees/$(employeeId)).data.lineUserId == request.auth.uid;
    }

    // วันที่ปัจจุบันตามเขตเวลาไทย (UTC+7) รูปแบบ YYYY-MM-DD
    // เทียบกับ leave.start (string YYYY-MM-DD) แบบ lexicographic ได้ตรง ๆ
    function bangkokTime() {
      return request.time + duration.value(7, 'h');
    }
    function pad2(n) {
      return (n < 10 ? '0' : '') + string(n);
    }
    function bangkokToday() {
      return string(bangkokTime().year())
        + '-' + pad2(bangkokTime().month())
        + '-' + pad2(bangkokTime().day());
    }

    // ─── Payroll month lock ──────────────────────────────────────
    // เดือน (YYYY-MM) ถูก "ปิดรอบถาวร" เมื่อพ้น lockAtMs (= ยืนยันยอดครั้งแรก
    // + 7 วัน) ที่เก็บไว้ใน payrollConfirms/{ym}. ใช้ร่วมกับฝั่ง UI
    // (src/utils/payrollLock.ts) — กันแก้ค่าคอม/ลา/เบิก ของเดือนที่ปิดรอบแล้ว
    // doc เก่าที่ไม่มี lockAtMs → ถือว่ายังไม่ล็อก (UI fallback จัดการต่อ)
    // defensive: ถ้า doc ไม่มี / ไม่มี lockAtMs / lockAtMs ≤ 0 → ถือว่ายัง
    // ไม่ล็อก. ใช้ data.get(field, default) เพื่อไม่ throw เมื่อ field หาย
    function monthLocked(ym) {
      let path = /databases/$(database)/documents/payrollConfirms/$(ym);
      return exists(path)
        && get(path).data.get('lockAtMs', 0) > 0
        && request.time.toMillis() > get(path).data.get('lockAtMs', 0);
    }

    function isSelfProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "avatar",
        "avatarType",
        "avatarImageUrl",
        "bank",
        "bankAccountNumber",
        "updatedAt"
      ]);
    }

    function validSelfProfileData() {
      return request.resource.data.avatar is string
        && request.resource.data.avatar.size() <= 8
        && request.resource.data.avatarType in ["text", "emoji", "image"]
        && (!("avatarImageUrl" in request.resource.data)
          || request.resource.data.avatarImageUrl == null
          || (request.resource.data.avatarImageUrl is string && request.resource.data.avatarImageUrl.size() <= 2048))
        && (!("bank" in request.resource.data)
          || (request.resource.data.bank is string && request.resource.data.bank.size() <= 80))
        && (!("bankAccountNumber" in request.resource.data)
          || (request.resource.data.bankAccountNumber is string && request.resource.data.bankAccountNumber.size() <= 40))
        && request.resource.data.updatedAt is int;
    }

    function validLeaveCreate() {
      return request.resource.data.keys().hasOnly([
          "employeeId",
          "employeeName",
          "type",
          "start",
          "end",
          "days",
          "reason",
          "submitted",
          "createdAt",
          "createdByAdmin"
        ])
        && request.resource.data.employeeName ==
          get(/databases/$(database)/documents/employees/$(request.resource.data.employeeId)).data.name
        && request.resource.data.type in ["personal", "sick"]
        && request.resource.data.start is string
        && request.resource.data.end is string
        && request.resource.data.days is int
        && request.resource.data.days > 0
        && (!("reason" in request.resource.data)
          || (request.resource.data.reason is string && request.resource.data.reason.size() <= 500))
        && (!("submitted" in request.resource.data)
          || (request.resource.data.submitted is string && request.resource.data.submitted.size() <= 120))
        && request.resource.data.createdAt is int
        // createdByAdmin = true ตั้งได้แค่ admin · พนักงานต้องไม่ส่ง field นี้หรือต้องเป็น false
        && (!("createdByAdmin" in request.resource.data)
          || (request.resource.data.createdByAdmin is bool
            && (!request.resource.data.createdByAdmin || isAdmin())));
    }

    function validAdvanceCreate() {
      return request.resource.data.keys().hasOnly([
          "employeeId",
          "employeeName",
          "amount",
          "reason",
          "month",
          "status",
          "submittedAt"
        ])
        && request.resource.data.employeeName ==
          get(/databases/$(database)/documents/employees/$(request.resource.data.employeeId)).data.name
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.month is string
        && request.resource.data.status == "pending"
        && request.resource.data.submittedAt is string;
    }

    // ─── Employees ───────────────────────────────────────────────
    // อ่าน: admin หรือเจ้าของ LINE-linked document
    // เขียน: admin; employee แก้ได้เฉพาะ profile/bank fields ของตัวเอง
    match /employees/{employeeId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.lineUserId == request.auth.uid);
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isEmployeeOwner(employeeId) && isSelfProfileUpdate() && validSelfProfileData());
    }

    // ─── Leaves ──────────────────────────────────────────────────
    // อ่าน/สร้าง/ลบ: admin หรือเจ้าของ employee document
    // แก้ไข: admin only
    match /leaves/{leaveId} {
      allow read:   if isAdmin() || isEmployeeOwner(resource.data.employeeId);
      // สร้าง/แก้/ลบ ของเดือนที่ปิดรอบแล้ว (locked) ไม่ได้ — แม้แต่ admin
      // admin สร้างให้พนักงานคนอื่นได้ (ลืมกดลา) · พนักงานสร้างของตัวเองได้
      allow create: if (isAdmin() || isEmployeeOwner(request.resource.data.employeeId))
        && validLeaveCreate()
        && !monthLocked(request.resource.data.start[0:7]);
      allow update: if isAdmin() && !monthLocked(resource.data.start[0:7]);
      // ลบเอง: เฉพาะใบลาที่ยังไม่เริ่ม (start > วันนี้)
      // วันนี้และอดีต: admin เท่านั้น · เดือนปิดรอบแล้วลบไม่ได้
      allow delete: if !monthLocked(resource.data.start[0:7])
        && (isAdmin()
          || (isEmployeeOwner(resource.data.employeeId)
            && resource.data.start > bangkokToday()));
    }

    // ─── Salaries ────────────────────────────────────────────────
    // PHASE 2: ล็อกอ่านเฉพาะ admin หรือเจ้าของ salary doc — sensitive fields
    // (note, customDeductions, socialSecurity, slipUrl) จึงไม่หลุดข้ามคน.
    // peer data ที่ pool calc ต้องใช้ถูกย้ายไปอ่านจาก collection
    // public `poolSnapshots/{ym}` แทน (mirror ทุกครั้งที่ admin save salary)
    // เขียนไม่ได้ถ้าเดือนนั้นปิดรอบแล้ว (พ้น 7 วันหลังยืนยันยอด)
    match /salaries/{employeeId}/months/{yearMonth} {
      allow read:   if isAdmin() || isEmployeeOwner(employeeId);
      allow write:  if isAdmin() && !monthLocked(yearMonth);
    }

    // collectionGroup(db, "months") — ใช้ใน subscribeAllSalaries (admin เท่านั้น)
    // พนักงานใช้ subscribeEmployeeSalaries(employeeId) ที่ไม่พึ่ง collectionGroup
    match /{path=**}/months/{yearMonth} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Employee Loans (เงินกู้ผ่อนคืน — admin สร้าง) ──────────
    // อ่าน: admin หรือเจ้าของ · เขียน: admin เท่านั้น
    match /employeeLoans/{loanId} {
      allow read:  if isAdmin() || isEmployeeOwner(resource.data.employeeId);
      allow write: if isAdmin();
    }

    // ─── Pool Adjustments (admin หักจากกองกลาง ระดับเดือน) ─────
    // {excludedNormalPieces, excludedBuyPieces, notes} — 1 doc/เดือน
    // อ่าน: signed-in (ฝั่งพนักงานใช้คำนวณ pool ของตัวเอง)
    // เขียน: admin · ปิดรอบแล้ว (lockAtMs) ห้ามเขียน
    match /poolAdjustments/{yearMonth} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() && !monthLocked(yearMonth);
    }

    // ─── Pool Snapshots (public, non-sensitive copy ของ pool fields) ───
    // 1 doc/เดือน, shape: { [empId]: { pieces, roleId, poolExclusion,
    // totalLeaveDays } } — ทุกคนอ่านได้เพื่อคำนวณ pool ของกลุ่ม
    match /poolSnapshots/{yearMonth} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Advances ────────────────────────────────────────────────
    // อ่าน: admin หรือเจ้าของ
    // สร้าง: เจ้าของ
    // อนุมัติ/ปฏิเสธ: admin
    match /advances/{advanceId} {
      allow read:   if isAdmin() || isEmployeeOwner(resource.data.employeeId);
      allow create: if isEmployeeOwner(request.resource.data.employeeId)
        && validAdvanceCreate()
        && !monthLocked(request.resource.data.month);
      allow update: if isAdmin() && !monthLocked(resource.data.month);
      allow delete: if isAdmin() && !monthLocked(resource.data.month);
    }

    // ─── Roles ───────────────────────────────────────────────────
    // อ่าน: ทุกคน, เขียน: admin
    match /roles/{roleId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Duties (ตารางเวร) ──────────────────────────────────────
    // read: signed-in (พนักงานเห็น "วันนี้ฉันมีเวรอะไร" + "ใครมีเวรไหน")
    // write: admin
    match /duties/{dutyId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Duty Assignments Today (server-computed snapshot) ──────
    // Cloud Function (recomputeDutyAssignments) compute + เขียน — มาจาก
    // duty CRUD trigger + scheduled refresh 00:01. Snapshot self-contained
    // มี assignments + safe employee projection (id/name/nickname/avatar/
    // displayOrder เท่านั้น — ไม่มี salary/bank/lineUserId/piece rates)
    // signed-in อ่านได้ทั้งหมด · client write ปิดทั้งหมด (Admin SDK only)
    match /dutyAssignmentsToday/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ─── Server-side config/secrets ─────────────────────────────
    // Cloud Functions use the Admin SDK and bypass rules. Clients should never
    // read or write runtime secrets, even if future rules become broader.
    // ข้อยกเว้น: notifications doc ให้ admin อ่าน/เขียนได้ผ่าน UI
    // (เปิด-ปิด LINE notification รายประเภท — ไม่ใช่ secret)
    match /config/notifications {
      allow read, write: if isAdmin();
    }
    // ปฏิทินวันเปิด-ปิดร้าน: ทุกคน signed-in อ่านได้ (ใช้กรองหน้าที่/ลา) ·
    // admin เท่านั้นแก้
    match /config/storeCalendar {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    // ราคาทองคำไทย: ทุกคน signed-in อ่าน (ใช้ใน knowledge calculators +
    // ตารางค่าเปลี่ยน) · admin update วันละครั้ง
    match /config/goldPrice {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    // ค่าแรงเริ่มต้น (ทอง 96.5%): ทุกคน signed-in อ่าน (ใช้ใน knowledge
    // labor table + live sell price + change price calc) · admin แก้
    match /config/laborCost {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    // ค่าบล็อก + ค่าประกัน (ทองคำแท่ง / เงินแท่ง): ทุกคน signed-in อ่าน
    // (ใช้ใน knowledge block cost table) · admin แก้
    match /config/blockCost {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    // แต้มสะสมแลกทองคำแท่ง: ทุกคน signed-in อ่าน
    // (ใช้ใน knowledge loyalty points redeem table) · admin แก้
    match /config/loyaltyPoints {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /config/{document} {
      allow read, write: if false;
    }

    // ─── Payroll Confirms ────────────────────────────────────────
    // read: signed-in (พนักงานใช้เช็คว่า admin ยืนยันยอดแล้วหรือยัง
    //       เพื่อปลดล็อกการพิมพ์สลิปเงินเดือน)
    // write: admin
    // write: admin · แต่เมื่อปิดรอบถาวรแล้ว (พ้น lockAtMs) ยืนยันใหม่ไม่ได้
    match /payrollConfirms/{key} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && !monthLocked(key);
    }

    // ─── Cert Counters (running number ใบรับรอง) ─────────────────
    // เก็บที่ certCounters/{พ.ศ.} — เพิ่มได้ทีละ 1 (transaction)
    // ไม่ sensitive — เปลี่ยน count ผิดอย่างมากก็ทำให้เลขกระโดด ไม่กระทบความปลอดภัย
    match /certCounters/{year} {
      allow read: if isSignedIn();
      // create เอกสารแรกของปี: count ต้อง = 1
      allow create: if isSignedIn()
        && request.resource.data.count == 1;
      // update: count ต้องเพิ่มทีละ 1 (กันการรีเซ็ตหรือกระโดด)
      allow update: if isSignedIn()
        && request.resource.data.count == resource.data.count + 1;
    }
  }
}
