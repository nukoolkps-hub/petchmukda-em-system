# ╔═══════════════════════════════════════════════════════════════════╗
# ║  Frontend Vite Env                                               ║
# ║  Copy to .env.development.local or .env.production.local          ║
# ║  Dev Firebase config (mock) lives in src/firebase/firebaseConfig.json ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── Firebase Web Config (production build เท่านั้น) ───────────────
# dev ไม่ต้องตั้ง — ใช้ mock จาก src/firebase/firebaseConfig.json
# production: ใส่ค่าใน .env.production.local หรือ GitHub Secrets (ดู deploy.yml)
# หมายเหตุ: Firebase web apiKey ไม่ใช่ secret จริง (ฝัง client ได้)
#          ความปลอดภัยอยู่ที่ Firestore/Storage Rules + จำกัด key ใน GCP Console
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=petchmukda-bot.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=petchmukda-bot
VITE_FIREBASE_STORAGE_BUCKET=petchmukda-bot.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=103538947541
VITE_FIREBASE_APP_ID=1:103538947541:web:5a87a3421cbbf3ad69395c
VITE_FIREBASE_MEASUREMENT_ID=G-YYB26ELHDY
VITE_FIRESTORE_DATABASE_ID=petchmukda-bot

# ─── Optional: เปิด-ปิด Firebase Emulators ─────────────────────
# ไม่ต้องตั้ง — เปิดอัตโนมัติตอน `npm run dev` (import.meta.env.DEV)
# production build ควรตั้ง false หรือไม่ต้องตั้ง
# VITE_USE_EMULATORS=false

# ─── LINE Login ────────────────────────────────────────────────
# Channel ID จาก LINE Developers Console (LINE Login channel)
# ต้องมีตอน `npm run build` เพราะ Vite ฝังค่านี้ลงใน bundle
VITE_LINE_LOGIN_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID

# ─── LINE & Secrets ────────────────────────────────────────────
# LINE secrets (channel secret, access token) ถูกเก็บใน Firestore /config/secrets
# ดู FIREBASE_SETUP.md สำหรับวิธีเพิ่ม secrets ใน Firestore
