# ╔═══════════════════════════════════════════════════════════════════╗
# ║  Firebase Configuration                                           ║
# ║  คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Firebase Console  ║
# ║  https://console.firebase.google.com → Settings → Your apps      ║
# ╚═══════════════════════════════════════════════════════════════════╝

VITE_FIREBASE_API_KEY=AIzaSy....
VITE_FIREBASE_AUTH_DOMAIN=muktha-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=muktha-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=muktha-xxxxx.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abcdef

# ─── Optional: เปิด-ปิด Firebase mode ──────────────────────────
# false = ใช้ in-memory state (โหมด demo)
# true  = ใช้ Firestore (production)
VITE_USE_FIREBASE=true

# ─── Optional: เปิด-ปิด Firebase Emulators ─────────────────────
# ไม่ต้องตั้ง — เปิดอัตโนมัติตอน `pnpm dev` (import.meta.env.DEV)
# ตั้ง false เพื่อบังคับใช้ production Firebase ตอน dev
# VITE_USE_EMULATORS=false

# ─── LINE Login ────────────────────────────────────────────────
# Channel ID จาก LINE Developers Console (LINE Login channel)
VITE_LINE_LOGIN_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID

# ─── LINE & Secrets ────────────────────────────────────────────
# LINE secrets (channel secret, access token) ถูกเก็บใน Firestore /config/secrets
# ดู FIREBASE_SETUP.md สำหรับวิธีเพิ่ม secrets ใน Firestore
