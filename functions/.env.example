FIRESTORE_DATABASE_ID=petchmukda-bot

# Required for the bootstrapAdmin callable function.
ADMIN_BOOTSTRAP_SECRET=your-local-bootstrap-secret

# LINE Login channel credentials from LINE Developers Console.
LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id
LINE_LOGIN_CHANNEL_SECRET=your-line-login-channel-secret

# Admin LINE user ID is also used for admin-only LINE Login.
# Send "ไอดีฉัน" in a private chat with the bot to get this value.
ADMIN_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: required only for LINE push notifications.
LINE_CHANNEL_ACCESS_TOKEN=your-messaging-api-channel-access-token
LINE_CHANNEL_SECRET=your-messaging-api-channel-secret
